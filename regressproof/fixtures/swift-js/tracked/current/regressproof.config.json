{
  "projectName": "RegressProof Fixture Swift",
  "baselineRef": "HEAD~1",
  "checks": {
    "commandTimeoutMs": 8000,
    "quick": [
      "swift -module-cache-path .swift-module-cache scripts/lint.swift",
      "swift -module-cache-path .swift-module-cache scripts/typecheck.swift"
    ],
    "full": [
      "swift -module-cache-path .swift-module-cache scripts/test.swift"
    ]
  },
  "reports": {
    "defaultFormat": "json",
    "ciFailOn": [
      "confirmed_agent_fault"
    ]
  },
  "usage": {
    "mode": "estimated",
    "estimatedCostUsd": 0.01
  },
  "credits": {
    "enabled": true,
    "policy": "refund_estimated_cost_on_confirmed_agent_fault"
  }
}
