{
  "projectName": "RegressProof Fixture Lint JS",
  "baselineRef": "HEAD~1",
  "checks": {
    "commandTimeoutMs": 5000,
    "quick": [
      "node scripts/lint.js",
      "node scripts/typecheck.js"
    ],
    "full": [
      "node scripts/test.js"
    ]
  },
  "reports": {
    "defaultFormat": "json",
    "ciFailOn": [
      "confirmed_agent_fault"
    ]
  },
  "usage": {
    "mode": "estimated",
    "estimatedCostUsd": 0.01
  },
  "credits": {
    "enabled": true,
    "policy": "refund_estimated_cost_on_confirmed_agent_fault"
  }
}
