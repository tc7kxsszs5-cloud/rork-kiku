{
  "projectName": "RegressProof Fixture Test JS",
  "baselineRef": "HEAD~1",
  "baseline": {
    "mode": "full_snapshot"
  },
  "checks": {
    "commandTimeoutMs": 30000,
    "quick": [
      "node scripts/lint.js",
      "node scripts/test.js"
    ],
    "full": [
      "node scripts/build.js"
    ]
  },
  "reports": {
    "defaultFormat": "json",
