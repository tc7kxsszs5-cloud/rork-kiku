{
  "projectName": "RegressProof Demo Fast Path",
  "baselineRef": "HEAD~1",
  "checks": {
    "commandTimeoutMs": 5000,
    "quick": [
      "node -e \"process.stdout.write('quick-check-ok')\""
    ],
    "full": [
      "node -e \"process.stdout.write('full-check-ok')\""
    ]
  },
  "reports": {
    "defaultFormat": "json",
    "ciFailOn": [
      "confirmed_agent_fault"
    ]
  },
  "usage": {
    "mode": "estimated",
    "estimatedCostUsd": 0.01
  },
  "credits": {
    "enabled": true,
    "policy": "refund_estimated_cost_on_confirmed_agent_fault"
  }
}
